#!/bin/bash
set -e

echo "=== Pre-commit checks ==="

# Format check (fail if files would change)
UNFORMATTED=$(gofmt -l . 2>/dev/null || true)
if [ -n "$UNFORMATTED" ]; then
    echo "FAIL: Unformatted Go files:"
    echo "$UNFORMATTED"
    echo "Run: go fmt ./..."
    exit 1
fi
echo "  fmt: ok"

# Vet
echo "  vet: running..."
go vet ./... 2>&1
echo "  vet: ok"

# Lint (if golangci-lint is installed)
if command -v golangci-lint &>/dev/null; then
    echo "  lint: running..."
    golangci-lint run --timeout 5m 2>&1
    echo "  lint: ok"
else
    echo "  lint: skipped (golangci-lint not installed)"
fi

# Build check
echo "  build: running..."
go build -o /dev/null ./cmd/mnemonic 2>&1
echo "  build: ok"

echo "=== All checks passed ==="
